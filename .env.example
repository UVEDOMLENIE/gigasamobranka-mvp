# GigaSamobranka MVP — env template
# Скопируй в .env.local и заполни значения.

# ---------- LLM ----------
# По умолчанию работает mock fallback. Реальные ключи можно ввести на /settings
# или задать здесь серверно.
LLM_PROVIDER=scarlex

# Scarlex V2 / OpenAI-compatible
SCARLEX_API_KEY=
SCARLEX_BASE_URL=https://api.scarlex.ru/v1
SCARLEX_MODEL=claude-sonnet-4.6

# GigaChat
GIGACHAT_API_KEY=
GIGACHAT_AUTH_KEY=
GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1
GIGACHAT_OAUTH_URL=https://ngw.devices.sberbank.ru:9443/api/v2/oauth
GIGACHAT_SCOPE=GIGACHAT_API_PERS

# true → не дёргать реальный API, использовать локальный детерминированный mock
USE_MOCK_LLM=false

# ---------- Database ----------
# Локально: SQLite через better-sqlite3.
DATABASE_URL=file:./local.db
DATABASE_AUTH_TOKEN=

# Prod (Vercel + Turso): заменить на libsql://<name>.turso.io + auth token.
# DATABASE_URL=libsql://gigasamobranka.turso.io
# DATABASE_AUTH_TOKEN=

# ---------- Rate limit ----------
LLM_REQUESTS_PER_HOUR=30

# ---------- Cookies ----------
OWNER_KEY_COOKIE_NAME=gs_owner
